# ===========================================
# ClimBetter — Environment Variables Template
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file.

# --- TimescaleDB ---
POSTGRES_USER=climbetter
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32
POSTGRES_DB=climbetter
KEYCLOAK_DB_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32
KC_HOSTNAME=auth.climbetter.com

# --- Traefik ---
ACME_EMAIL=admin@climbetter.com
